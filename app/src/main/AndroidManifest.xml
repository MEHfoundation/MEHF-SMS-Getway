<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.mehf.smsgateway">

    <!-- Aapki purani permissions -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Nayi Permissions Background Service aur App ko zinda rakhne ke liye -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Android 13+ mein foreground service ki notification dikhane ke liye -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/logo"
        android:label="MEHF SMS Gateway"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar">
        
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Naya: Background mein chalne wali Foreground Service -->
        <service
            android:name=".SmsBackgroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Aapka purana receiver (Dhyan rakhein ki MainActivity mein SmsResultReceiver ek 'public static' class honi chahiye) -->
        <receiver 
            android:name=".MainActivity$SmsResultReceiver" 
            android:exported="true">
            <intent-filter>
                <action android:name="SMS_SENT_ACTION" />
            </intent-filter>
        </receiver>
        
    </application>
</manifest>
